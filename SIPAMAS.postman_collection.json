{
  "info": {
    "name": "SIPAMAS API",
    "_postman_id": "sipamas-api-collection",
    "description": "Sistem Pelaporan Masyarakat - REST API Collection\n\n**Base URL:** http://localhost:8000/api\n\n**Cara penggunaan:**\n1. Jalankan request Register atau Login\n2. Salin token dari response Login\n3. Set Authorization → Bearer Token pada setiap request yang membutuhkan autentikasi",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Budi Santoso\",\n  \"email\": \"budi@example.com\",\n  \"phone\": \"081234567890\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/register",
              "host": ["{{base_url}}"],
              "path": ["register"]
            },
            "description": "Registrasi pengguna baru. Sertakan name, email, phone, password, dan password_confirmation."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('Token saved: ' + json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"budi@example.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/login",
              "host": ["{{base_url}}"],
              "path": ["login"]
            },
            "description": "Login dengan email dan password. Token JWT akan otomatis tersimpan ke variabel {{token}}."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/logout",
              "host": ["{{base_url}}"],
              "path": ["logout"]
            },
            "description": "Logout dan invalidasi token JWT yang aktif."
          }
        }
      ]
    },
    {
      "name": "👤 Profile",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/profile",
              "host": ["{{base_url}}"],
              "path": ["profile"]
            },
            "description": "Melihat data profil pengguna yang sedang login."
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Budi Santoso Updated\",\n  \"email\": \"budi.baru@example.com\",\n  \"phone\": \"089876543210\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/profile",
              "host": ["{{base_url}}"],
              "path": ["profile"]
            },
            "description": "Mengubah nama, email, dan/atau nomor telepon pengguna. Semua field bersifat opsional."
          }
        }
      ]
    },
    {
      "name": "📋 Laporan",
      "item": [
        {
          "name": "Buat Laporan",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Jalan Rusak di RT 05", "type": "text" },
                { "key": "category_id", "value": "1", "type": "text" },
                { "key": "region", "value": "Kec. Ciledug, Kota Tangerang", "type": "text" },
                { "key": "location", "value": "Jl. Mawar No. 10", "type": "text" },
                { "key": "description", "value": "Jalan berlubang cukup dalam dan membahayakan pengendara motor maupun mobil.", "type": "text" },
                { "key": "evidence_photo", "type": "file", "src": "" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/reports",
              "host": ["{{base_url}}"],
              "path": ["reports"]
            },
            "description": "Membuat laporan baru. Status otomatis diset ke 'Menunggu Verifikasi'. Field evidence_photo bersifat opsional (jpg/png, maks 2MB)."
          }
        },
        {
          "name": "Daftar Semua Laporan",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/reports",
              "host": ["{{base_url}}"],
              "path": ["reports"]
            },
            "description": "Melihat semua laporan dari seluruh pengguna."
          }
        },
        {
          "name": "Detail Laporan",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/reports/1",
              "host": ["{{base_url}}"],
              "path": ["reports", "1"]
            },
            "description": "Melihat detail laporan berdasarkan ID."
          }
        },
        {
          "name": "Hapus Laporan",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/reports/1",
              "host": ["{{base_url}}"],
              "path": ["reports", "1"]
            },
            "description": "Menghapus laporan milik sendiri. Hanya bisa menghapus laporan yang dibuat oleh pengguna yang sedang login."
          }
        }
      ]
    },
    {
      "name": "📁 Histori Laporan Saya",
      "item": [
        {
          "name": "Laporan Saya",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/my-reports",
              "host": ["{{base_url}}"],
              "path": ["my-reports"]
            },
            "description": "Melihat semua laporan yang pernah dibuat oleh pengguna yang sedang login."
          }
        },
        {
          "name": "Detail Laporan Saya",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/my-reports/1",
              "host": ["{{base_url}}"],
              "path": ["my-reports", "1"]
            },
            "description": "Melihat detail laporan milik sendiri berdasarkan ID."
          }
        }
      ]
    },
    {
      "name": "🏷️ Kategori",
      "item": [
        {
          "name": "Daftar Kategori",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/categories",
              "host": ["{{base_url}}"],
              "path": ["categories"]
            },
            "description": "Melihat semua kategori laporan yang tersedia: Infrastruktur, Kebersihan, Keamanan, Fasilitas Umum."
          }
        }
      ]
    },
    {
      "name": "📊 Status",
      "item": [
        {
          "name": "Daftar Status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/statuses",
              "host": ["{{base_url}}"],
              "path": ["statuses"]
            },
            "description": "Melihat semua status laporan: Menunggu Verifikasi, Diproses, Selesai, Ditolak."
          }
        },
        {
          "name": "Status Laporan by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/reports/1/status",
              "host": ["{{base_url}}"],
              "path": ["reports", "1", "status"]
            },
            "description": "Melihat status terkini dari laporan berdasarkan ID laporan."
          }
        }
      ]
    }
  ]
}
